# --- Supabase (local) -------------------------------------------------------
# Run `npx supabase start` and copy the printed values here.
# Local API runs on port 54521 (default ports offset by +200).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54521"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather. Used to push alert notifications to users.
TELEGRAM_BOT_TOKEN=""

# --- Resend -----------------------------------------------------------------
# Used for AI monitoring report emails.
RESEND_API_KEY=""
# Verified sender address used for AI monitoring emails.
RESEND_FROM_EMAIL="Trading AI <reports@example.com>"

# --- Anthropic Claude -------------------------------------------------------
ANTHROPIC_API_KEY=""

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
